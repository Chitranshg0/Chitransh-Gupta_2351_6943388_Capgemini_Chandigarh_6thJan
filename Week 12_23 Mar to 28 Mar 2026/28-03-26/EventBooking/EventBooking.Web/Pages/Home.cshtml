@page
@model IndexModel

<!-- 🔐 AUTH CHECK -->
<script>
if(!localStorage.getItem("token")){
    window.location.href = "/Login";
}
</script>

<!-- 🎨 STYLES -->
<style>
body {
    background: linear-gradient(135deg, #eef2f3, #dfe9f3);
}

/* HEADER */
.header-box {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
    padding: 25px;
    border-radius: 15px;
}

/* EVENT CARD */
.event-card {
    border-radius: 15px;
    transition: 0.3s;
}
.event-card:hover {
    transform: translateY(-6px);
}

/* BOOKING CARD */
.booking-card {
    border-left: 5px solid #667eea;
    border-radius: 12px;
}

/* BUTTON */
.btn-custom {
    border-radius: 25px;
}

/* MODAL */
.modal-content {
    border-radius: 15px;
}
</style>

<div class="container py-4">

    <!-- 🔷 HEADER -->
    <div class="header-box mb-4 shadow">
        <h2 class="fw-bold">🎉 Upcoming Events</h2>
        <p>Explore and book your favorite events easily</p>
    </div>

    <!-- 🔷 EVENTS -->
    <div class="row" id="eventsList"></div>

    <hr class="my-5"/>

    <!-- 🔷 BOOKINGS -->
    <h4 class="fw-bold mb-3">📄 Your Bookings</h4>
    <div id="bookingList"></div>

</div>

<!-- 🔥 BOOKING MODAL -->
<div class="modal fade" id="bookingModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content p-3">

      <h5 class="fw-bold mb-3">🎟 Book Event</h5>

      <input type="text" id="userName" class="form-control mb-2" placeholder="Enter your name">
      <input type="number" id="seatCount" class="form-control mb-3" placeholder="Enter seats">

      <button class="btn btn-primary w-100 btn-custom" onclick="confirmBooking()">Confirm Booking</button>

    </div>
  </div>
</div>

<script>
let selectedEventId = null;

function getToken(){
    return localStorage.getItem("token");
}

/* 🔷 LOAD EVENTS */
function loadEvents() {
    fetch("http://localhost:5003/api/events")
    .then(res => res.json())
    .then(data => {

        let html = "";

        data.forEach(e => {
            html += `
            <div class="col-md-4">
                <div class="card event-card shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="fw-bold">${e.title}</h5>
                        <p class="text-muted mb-1">📍 ${e.location}</p>
                        <p class="text-muted mb-1">📅 ${new Date(e.date).toLocaleDateString()}</p>
                        <p class="text-muted">🎟 Seats: ${e.availableSeats}</p>

                        <button class="btn btn-dark w-100 mt-2 btn-custom"
                            onclick="openModal(${e.id})">
                            🎟 Book Now
                        </button>
                    </div>
                </div>
            </div>`;
        });

        document.getElementById("eventsList").innerHTML = html;
    });
}

/* 🔥 OPEN MODAL */
function openModal(eventId){
    selectedEventId = eventId;

    let modal = new bootstrap.Modal(document.getElementById('bookingModal'));
    modal.show();
}

/* 🔥 CONFIRM BOOKING */
function confirmBooking(){

    let name = document.getElementById("userName").value;
    let seats = document.getElementById("seatCount").value;

    if(!name || !seats){
        alert("Please fill all fields");
        return;
    }

    fetch("http://localhost:5003/api/bookings", {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + getToken()
        },
        body: JSON.stringify({
            eventId: selectedEventId,
            userId: name,
            seatsBooked: parseInt(seats)
        })
    })
    .then(res => res.text())
    .then(msg => {
        alert(msg);

        loadBookings();
        loadEvents();

        document.getElementById("userName").value = "";
        document.getElementById("seatCount").value = "";

        bootstrap.Modal.getInstance(document.getElementById('bookingModal')).hide();
    });
}

/* 🔷 LOAD BOOKINGS */
function loadBookings(){
    let token = getToken();

    if(!token){
        document.getElementById("bookingList").innerHTML =
            `<p class="text-muted">Login to see your bookings</p>`;
        return;
    }

    fetch("http://localhost:5003/api/bookings", {
        headers: {
            "Authorization": "Bearer " + token
        }
    })
    .then(res => res.json())
    .then(data => {

        let html = "";

        if(data.length === 0){
            html = `<p class="text-muted">No bookings yet</p>`;
        }

        data.forEach(b => {
            html += `
            <div class="card booking-card shadow-sm p-3 mb-3">
                <div class="d-flex justify-content-between align-items-center">

                    <div>
                        <p class="mb-1"><b>👤 User:</b> ${b.userId}</p>
                        <p class="mb-1"><b>🎫 Event ID:</b> ${b.eventId}</p>
                        <p class="mb-0"><b>💺 Seats:</b> ${b.seatsBooked}</p>
                    </div>

                    <button onclick="cancelBooking(${b.id})"
                        class="btn btn-danger btn-sm btn-custom">
                        ❌ Cancel
                    </button>

                </div>
            </div>`;
        });

        document.getElementById("bookingList").innerHTML = html;
    });
}

/* ❌ CANCEL BOOKING */
function cancelBooking(id){
    fetch(`http://localhost:5003/api/bookings/cancel/${id}`, {
        method: "DELETE",
        headers: {
            "Authorization": "Bearer " + getToken()
        }
    })
    .then(res => res.text())
    .then(msg => {
        alert(msg);
        loadBookings();
        loadEvents();
    });
}

/* 🚀 INIT */
loadEvents();
loadBookings();
</script>