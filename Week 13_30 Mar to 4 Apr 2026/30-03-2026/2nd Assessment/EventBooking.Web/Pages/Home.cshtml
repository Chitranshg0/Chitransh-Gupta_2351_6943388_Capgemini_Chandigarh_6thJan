@page
@model IndexModel

<script>
if(!localStorage.getItem("token")){
    window.location.href = "/Login";
}
</script>

<div class="container">

<!-- 🔷 ADMIN SECTION -->

<div id="adminSection" class="mb-3"></div>

<!-- 🔷 ADD EVENT FORM -->

<div id="addEventForm" style="display:none;" class="card p-3 mb-4 shadow-sm">
    <h5 class="fw-bold mb-3">➕ Add Event</h5>
    <input id="eventTitle" class="form-control mb-2" placeholder="Event Title" />
    <input id="eventDescription" class="form-control mb-2" placeholder="Description" />
    <input id="eventLocation" class="form-control mb-2" placeholder="Location" />
    <input id="eventSeats" type="number" class="form-control mb-2" placeholder="Seats" />
    <input id="eventDate" type="date" class="form-control mb-3" />
    <button onclick="addEvent()" class="btn btn-success">Save Event</button>
</div>

<!-- 🔷 HEADER -->

<div class="mb-4">
    <h2 class="fw-bold">🎉 Upcoming Events</h2>
    <p class="text-muted">Explore and book your favorite events</p>
</div>

<!-- 🔷 EVENTS -->

<div class="row" id="eventsList"></div>

<hr class="my-4"/>

<!-- 🔷 BOOKINGS -->

<h4 class="fw-bold mb-3">📄 Your Bookings</h4>
<div id="bookingList"></div>

</div>

<script>
let eventsData = [];

function getToken(){
    return localStorage.getItem("token");
}

function getRole(){
    return localStorage.getItem("role");
}

function setupAdmin(){
    if(getRole() === "admin"){
        document.getElementById("adminSection").innerHTML = `
            <button class="btn btn-success" onclick="showAddEvent()">
                ➕ Add Event
            </button>
        `;
    }
}

function showAddEvent(){
    document.getElementById("addEventForm").style.display = "block";
}

function addEvent(){
    fetch("http://localhost:5003/api/events", {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + getToken()
        },
        body: JSON.stringify({
            title: document.getElementById("eventTitle").value,
            description: document.getElementById("eventDescription").value,
            location: document.getElementById("eventLocation").value,
            availableSeats: parseInt(document.getElementById("eventSeats").value),
            date: document.getElementById("eventDate").value
        })
    })
    .then(res => res.text())
    .then(msg => {
        alert(msg);
        document.getElementById("addEventForm").style.display = "none";
        loadEvents();
    });
}

function loadEvents() {
    fetch("http://localhost:5003/api/events")
    .then(res => res.json())
    .then(data => {

        eventsData = data;

        let html = "";
        let role = getRole();

        data.forEach(e => {

            let adminButtons = "";

            if(role === "admin"){
                adminButtons = `
                    <button class="btn btn-danger mt-2 w-100"
                        onclick="deleteEvent(${e.id})">
                        Delete Event
                    </button>
                `;
            }

            html += `
            <div class="col-md-4">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body">
                        <h5 class="fw-bold">${e.title}</h5>
                        <p class="text-muted mb-1">📍 ${e.location}</p>
                        <p class="text-muted mb-1">📅 ${new Date(e.date).toLocaleDateString()}</p>
                        <p class="text-muted">🎟 Seats: ${e.availableSeats}</p>

                        <button class="btn btn-dark w-100" onclick="book(${e.id})">
                            Book Now
                        </button>

                        ${adminButtons}
                    </div>
                </div>
            </div>`;
        });

        document.getElementById("eventsList").innerHTML = html;
    });
}

function deleteEvent(id){

    if(!confirm("Are you sure you want to delete this event?")){
        return;
    }

    fetch(`http://localhost:5003/api/events/${id}`, {
        method: "DELETE",
        headers: {
            "Authorization": "Bearer " + getToken()
        }
    })
    .then(res => res.text())
    .then(msg => {
        alert(msg);
        loadEvents();
        loadBookings();
    });
}

function book(eventId){

    if(!getToken()){
        alert("Please login first");
        return;
    }

    let name = prompt("Enter your name:");
    let seats = prompt("Enter number of seats:");

    if(!name || !seats){
        alert("All fields required");
        return;
    }

    fetch("http://localhost:5003/api/bookings", {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + getToken()
        },
        body: JSON.stringify({
            eventId: eventId,
            userId: name,
            seatsBooked: parseInt(seats)
        })
    })
    .then(res => res.text())
    .then(msg => {
        alert(msg);
        loadBookings();
        loadEvents();
    });
}

function loadBookings(){
    let token = getToken();

    if(!token){
        document.getElementById("bookingList").innerHTML =
            `<p class="text-muted">Login to see your bookings</p>`;
        return;
    }

    fetch("http://localhost:5003/api/bookings", {
        headers: {
            "Authorization": "Bearer " + token
        }
    })
    .then(res => res.json())
    .then(data => {

        let html = "";

        if(data.length === 0){
            html = `<p class="text-muted">No bookings yet</p>`;
        }

        data.forEach(b => {

            let event = eventsData.find(e => e.id === b.eventId);
            let eventName = event ? event.title : "Unknown Event";

            html += `
            <div class="card shadow-sm border-0 p-3 mb-3">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="mb-1"><b>User:</b> ${b.userId}</p>
                        <p class="mb-1"><b>Event:</b> ${eventName}</p>
                        <p class="mb-0"><b>Seats:</b> ${b.seatsBooked}</p>
                    </div>
                    <button onclick="cancelBooking(${b.id})" class="btn btn-danger btn-sm">
                        Cancel
                    </button>
                </div>
            </div>`;
        });

        document.getElementById("bookingList").innerHTML = html;
    });
}

function cancelBooking(id){
    fetch(`http://localhost:5003/api/bookings/cancel/${id}`, {
        method: "DELETE",
        headers: {
            "Authorization": "Bearer " + getToken()
        }
    })
    .then(res => res.text())
    .then(msg => {
        alert(msg);
        loadBookings();
        loadEvents();
    });
}

setupAdmin();
loadEvents();
setTimeout(loadBookings, 300);
</script>
