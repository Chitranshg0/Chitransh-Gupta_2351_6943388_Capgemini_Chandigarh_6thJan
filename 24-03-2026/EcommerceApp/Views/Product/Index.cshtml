@model List<Product>

<div class="container py-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Products</h2>
        <a href="/Product/Create" class="btn btn-success shadow-sm">
            Add Product
        </a>
    </div>

    <!-- Product Grid -->
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="card h-100 border-0 shadow-sm product-card">

                    <!-- Card Body -->
                    <div class="card-body d-flex flex-column">
                        
                        <h5 class="fw-semibold mb-2">@item.Name</h5>

                        <p class="text-muted mb-1">
                            Category: @item.Category?.Name
                        </p>

                        <h6 class="text-success fw-bold mb-3">
                            ₹@item.Price
                        </h6>

                        <!-- Spacer -->
                        <div class="mt-auto">

                            <!-- Buttons -->
                            <div class="d-flex justify-content-between">
                                <a href="/Product/Edit/@item.Id"
                                   class="btn btn-outline-warning btn-sm w-50 me-1">
                                    Edit
                                </a>

                                <a href="/Product/Delete/@item.Id"
                                   class="btn btn-outline-danger btn-sm w-50 ms-1">
                                    Delete
                                </a>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        }
    </div>

</div>

<!-- Optional Styling -->
<style>
    .product-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border-radius: 12px;
    }

    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }
</style>