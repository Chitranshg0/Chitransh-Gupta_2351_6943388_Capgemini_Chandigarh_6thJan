<div class="container py-5">

    <!-- Header -->
    <div class="mb-4">
        <h2 class="fw-bold">Admin Dashboard</h2>
        <p class="text-muted">Overview of system performance</p>
    </div>

    <div class="row g-4">

        <!-- Top Products Card -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-dark text-white fw-semibold">
                    Top Products
                </div>

                <div class="card-body">
                    @if (ViewBag.TopProducts != null && ViewBag.TopProducts.Count > 0)
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in ViewBag.TopProducts)
                            {
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>Product ID: @item.ProductId</span>
                                    <span class="badge bg-success">
                                        Sold: @item.TotalSold
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">No data available</p>
                    }
                </div>
            </div>
        </div>

        <!-- Pending Shipments Card -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-warning text-dark fw-semibold">
                    Pending Shipments
                </div>

                <div class="card-body">
                    @if (ViewBag.PendingOrders != null && ViewBag.PendingOrders.Count > 0)
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in ViewBag.PendingOrders)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>Order ID: @item.OrderId</span>

                                    <a href="/Admin/UpdateShipping/@item.Id"
                                       class="btn btn-outline-success btn-sm">
                                        Mark Shipped
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">No pending shipments</p>
                    }
                </div>
            </div>
        </div>

    </div>
</div>