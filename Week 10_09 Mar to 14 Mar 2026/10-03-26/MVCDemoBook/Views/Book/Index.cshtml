@model IEnumerable<MVCDemoBook.Models.BookModel>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Book Name</th>
            <th>Title</th>
            <th>Price</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.BookName</td>
            <td>@item.Title</td>
            <td>@item.Price</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.BookModelId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.BookModelId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.BookModelId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>