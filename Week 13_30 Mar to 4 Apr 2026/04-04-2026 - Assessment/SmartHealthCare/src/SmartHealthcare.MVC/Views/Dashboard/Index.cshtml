@{
    ViewData["Title"] = "Dashboard";
    var role = ViewBag.Role as string;
    var fullName = ViewBag.FullName as string;
}

<div class="container-fluid mt-4">

    <!-- WELCOME SECTION -->
    <div class="welcome-card mb-4">
        <h2>Welcome back, <strong>@fullName</strong> 👋</h2>
        <p>You are logged in as 
            <span class="role-badge">@role</span>
        </p>
    </div>

    <!-- ADMIN -->
    @if (role == "Admin")
    {
        <div class="row g-4">

            <div class="col-md-3">
                <div class="dash-card blue">
                    <i class="bi bi-people"></i>
                    <h5>Users</h5>
                    <a href="@Url.Action("Users","Admin")">Manage</a>
                </div>
            </div>

            <div class="col-md-3">
                <div class="dash-card green">
                    <i class="bi bi-hospital"></i>
                    <h5>Doctors</h5>
                    <a href="@Url.Action("Index","Doctor")">View</a>
                </div>
            </div>

            <div class="col-md-3">
                <div class="dash-card yellow">
                    <i class="bi bi-person-check"></i>
                    <h5>Patients</h5>
                    <a href="@Url.Action("Index","Appointment")">View</a>
                </div>
            </div>

            <div class="col-md-3">
                <div class="dash-card red">
                    <i class="bi bi-calendar-check"></i>
                    <h5>Appointments</h5>
                    <a href="@Url.Action("Index","Appointment")">View</a>
                </div>
            </div>
        </div>

        <!-- REPORT CARD -->
        <div class="glass-card mt-5 p-4 text-center">
            <h5 class="mb-3">📊 Analytics & Reports</h5>
            <p class="text-muted">View complete system insights</p>
            <a href="@Url.Action("Reports","Admin")" class="btn btn-dark px-4">View Reports</a>
        </div>
    }

    <!-- DOCTOR -->
    else if (role == "Doctor")
    {
        <div class="row g-4">

            <div class="col-md-4">
                <div class="dash-card blue">
                    <i class="bi bi-calendar"></i>
                    <h5>Appointments</h5>
                    <a href="@Url.Action("Index","Appointment")">View</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="dash-card gray">
                    <i class="bi bi-person"></i>
                    <h5>Profile</h5>
                    <a href="@Url.Action("Profile","Patient")">Edit</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="dash-card yellow">
                    <i class="bi bi-capsule"></i>
                    <h5>Prescriptions</h5>
                    <a href="#">Manage</a>
                </div>
            </div>
        </div>
    }

    <!-- PATIENT -->
    else if (role == "Patient")
    {
        <div class="row g-4">

            <div class="col-md-4">
                <div class="dash-card green">
                    <i class="bi bi-plus-circle"></i>
                    <h5>Book Appointment</h5>
                    <a href="@Url.Action("Create","Appointment")">Book Now</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="dash-card blue">
                    <i class="bi bi-calendar"></i>
                    <h5>My Appointments</h5>
                    <a href="@Url.Action("Index","Appointment")">View</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="dash-card yellow">
                    <i class="bi bi-person"></i>
                    <h5>Profile</h5>
                    <a href="@Url.Action("Profile","Patient")">Edit</a>
                </div>
            </div>
        </div>

        <!-- DOCTOR BROWSE -->
        <div class="glass-card mt-5 p-4 text-center">
            <h5>👨‍⚕️ Find Doctors</h5>
            <p class="text-muted">Explore healthcare professionals</p>
            <a href="@Url.Action("Index","Doctor")" class="btn btn-primary">Browse Doctors</a>
        </div>
    }
</div>

<style>
    /* Welcome */
    .welcome-card {
        background: linear-gradient(45deg, #007bff, #00c6ff);
        color: white;
        padding: 25px;
        border-radius: 15px;
    }

    .role-badge {
        background: white;
        color: #007bff;
        padding: 5px 12px;
        border-radius: 20px;
        font-weight: 600;
    }

    /* Cards */
    .dash-card {
        padding: 25px;
        border-radius: 15px;
        color: white;
        text-align: center;
        transition: 0.3s;
    }

    .dash-card i {
        font-size: 30px;
        margin-bottom: 10px;
    }

    .dash-card a {
        display: inline-block;
        margin-top: 10px;
        padding: 6px 15px;
        border-radius: 20px;
        background: white;
        color: black;
        text-decoration: none;
        font-weight: 500;
    }

    .dash-card:hover {
        transform: translateY(-5px);
    }

    /* Colors */
    .blue { background: linear-gradient(45deg, #007bff, #0056b3); }
    .green { background: linear-gradient(45deg, #28a745, #1e7e34); }
    .yellow { background: linear-gradient(45deg, #ffc107, #d39e00); }
    .red { background: linear-gradient(45deg, #dc3545, #a71d2a); }
    .gray { background: linear-gradient(45deg, #6c757d, #495057); }

    /* Glass */
    .glass-card {
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(10px);
        border-radius: 15px;
    }
</style>