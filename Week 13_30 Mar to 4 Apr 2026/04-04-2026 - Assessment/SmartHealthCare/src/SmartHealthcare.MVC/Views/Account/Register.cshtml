@model SmartHealthcare.Models.DTOs.RegisterDTO
@{
    ViewData["Title"] = "Register";
}

<div class="register-bg d-flex align-items-center justify-content-center">

    <div class="register-card p-4">

        <!-- HEADER -->
        <div class="text-center mb-4">
            <div class="logo mb-2">
                <i class="bi bi-hospital"></i>
            </div>
            <h3 class="fw-bold">Create Account</h3>
            <p class="text-muted small">Join Smart Healthcare</p>
        </div>

        <!-- FORM -->
        <form asp-action="Register" method="post" novalidate>

            <div asp-validation-summary="All" class="alert alert-danger small"></div>

            <!-- NAME -->
            <div class="form-floating mb-3">
                <input asp-for="FullName" class="form-control" placeholder="Full Name">
                <label>Full Name</label>
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <!-- EMAIL -->
            <div class="form-floating mb-3">
                <input asp-for="Email" type="email" class="form-control" placeholder="Email">
                <label>Email</label>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <!-- PASSWORD -->
            <div class="form-floating mb-3">
                <input asp-for="Password" type="password" class="form-control" placeholder="Password">
                <label>Password</label>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <!-- ROLE -->
            <div class="mb-3">
                <label class="small fw-bold mb-2">Register as</label>
                <select asp-for="Role" class="form-select">
                    <option value="Patient">Patient</option>
                    <option value="Doctor">Doctor</option>
                </select>
            </div>

            <!-- TERMS -->
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" required>
                <label class="form-check-label small">
                    I agree to Terms & Conditions
                </label>
            </div>

            <!-- BUTTON -->
            <button class="btn btn-register w-100 mb-3">
                Create Account
            </button>

        </form>

        <!-- FOOTER -->
        <div class="text-center">
            <small>
                Already have an account?
                <a asp-action="Login" class="fw-bold text-decoration-none">Login</a>
            </small>
        </div>

        <!-- BENEFITS -->
        <div class="benefits mt-4">
            <ul>
                <li>✔ Book appointments</li>
                <li>✔ Digital prescriptions</li>
                <li>✔ Access medical history</li>
            </ul>
        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    /* Background */
    .register-bg {
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea, #764ba2);
    }

    /* Card */
    .register-card {
        width: 100%;
        max-width: 420px;
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(12px);
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    /* Logo */
    .logo {
        font-size: 40px;
        color: #667eea;
    }

    /* Button */
    .btn-register {
        background: linear-gradient(45deg, #28a745, #1e7e34);
        color: white;
        border-radius: 30px;
        padding: 10px;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-register:hover {
        transform: scale(1.03);
    }

    /* Benefits */
    .benefits {
        background: #f1f5f9;
        padding: 10px;
        border-radius: 10px;
        font-size: 13px;
    }

    /* Inputs */
    .form-control:focus,
    .form-select:focus {
        border-color: #28a745;
        box-shadow: 0 0 0 0.2rem rgba(40,167,69,0.25);
    }
</style>